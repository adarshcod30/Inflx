# ===================================================================
# AutoStream Agentic Workflow — Environment Configuration
# ===================================================================
# Copy this file to .env and replace the placeholder with your key.
#
#   cp .env.example .env
#
# Get your API key from: https://aistudio.google.com/apikey
# ===================================================================

GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: override the default model (default: gemini-3.1-flash-lite-preview)
# AUTOSTREAM_MODEL=gemini-3.1-flash-lite-preview
